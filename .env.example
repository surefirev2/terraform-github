# Built by CI from .github/terraform-env-vars.conf via terraform-load-env.sh (1Password).
# Locally: copy to .env and fill values, or run terraform-load-env.sh with OP_SERVICE_ACCOUNT_TOKEN set.

# GitHub PAT (Docker entrypoint maps GITHUB_TOKEN -> TF_VAR_github_token if TF_VAR is unset)
GITHUB_TOKEN=ghp_your_token_here
# TF_VAR_github_token=ghp_your_token_here

# AWS — required for Terraform S3 backend (state + lockfile)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1

# Optional: Task Master / AI (see project docs)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
MISTRAL_API_KEY=your_mistral_key_here
XAI_API_KEY=YOUR_XAI_KEY_HERE
AZURE_OPENAI_API_KEY=your_azure_key_here
